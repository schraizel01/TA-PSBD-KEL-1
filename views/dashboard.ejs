<%- include('layout/header') %>

    <!-- HERO (TETAP DARI KODE AWAL) -->
    <div class="p-5 mb-4 bg-dark text-white rounded-4 position-relative overflow-hidden shadow-lg">
        <img src="https://images.unsplash.com/photo-1606144042614-b2417e99c4e3?q=80&w=2070&auto=format&fit=crop"
            class="position-absolute w-100 h-100 top-0 start-0 opacity-25" style="object-fit: cover; z-index: 0;">

        <div class="container-fluid py-4 position-relative" style="z-index: 1;">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="display-5 fw-bold mb-3">
                        <i class="fa-solid fa-gamepad text-warning me-2"></i>
                        Rental PS UNDIP Tembalang
                    </h1>
                    <p class="fs-4 text-light opacity-75">
                        Selamat bertugas,
                        <span class="text-warning fw-bold">
                            <%= username %>
                        </span>! Pantau meja, kelola reservasi mahasiswa, dan maksimalkan layanan hari ini.
                    </p>
                </div>

                <div class="col-md-4 text-center d-none d-md-block">
                    <i class="fa-brands fa-playstation text-white opacity-50" style="font-size: 10rem;"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- INFO CARD (TETAP) -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-start border-primary border-4 rounded-3 hover-lift">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle me-3">
                            <i class="fa-solid fa-clock fs-4"></i>
                        </div>
                        <h5 class="card-title text-secondary fw-bold mb-0">Jam Operasional</h5>
                    </div>
                    <p class="card-text text-muted mb-1">Buka Setiap Hari (Senin - Minggu)</p>
                    <h4 class="fw-bold text-white">24 Jam</h4>
                    <div class="mt-3">
                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i
                                class="fa-solid fa-circle-check me-1"></i> Buka</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-start border-danger border-4 rounded-3 hover-lift">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-danger bg-opacity-10 text-danger p-3 rounded-circle me-3">
                            <i class="fa-solid fa-map-location-dot fs-4"></i>
                        </div>
                        <h5 class="card-title text-secondary fw-bold mb-0">Lokasi & Kontak</h5>
                    </div>
                    <p class="card-text text-muted mb-1">Kawasan Kampus UNDIP</p>
                    <h6 class="fw-bold text-dark lh-base">Jl. Banjarsari Selatan No. 48,<br>Tembalang, Semarang</h6>
                    <div class="mt-3">
                        <a href="#" class="text-decoration-none text-success fw-bold"><i
                                class="fa-brands fa-whatsapp me-1"></i> +62 812-3456-7890</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-start border-warning border-4 rounded-3 hover-lift">
                <div class="card-body p-4">
                    <h5 class="fw-bold">Fasilitas</h5>
                    <ul class="list-unstyled mt-2 mb-0">
                        <li class="mb-2 text-white">
                            <i class="fa-solid fa-check me-2 text-accent"></i> Konsol PS5 & PS4 Pro Terbaru
                        </li>
                        <li class="mb-2 text-white">
                            <i class="fa-solid fa-check me-2 text-accent"></i> Smart TV 4K UHD 50-Inch
                        </li>
                        <li class="mb-2 text-white">
                            <i class="fa-solid fa-check me-2 text-accent"></i> Ruangan Full AC & Sofa Nyaman
                        </li>
                        <li class="mb-2 text-white">
                            <i class="fa-solid fa-check me-2 text-accent"></i> Free WiFi & Area Snack/Minuman
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- ========================= -->
    <!-- FITUR BARU: STATS -->
    <!-- ========================= -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Pelanggan</h6>
                <h3>
                    <%= stats.customers || 0 %>
                </h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Durasi Rata-rata</h6>
                <h3>
                    <%= (parseFloat(stats.avgDuration || 0)).toFixed(1) %> jam
                </h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Pendapatan</h6>
                <h3>Rp <%= (stats.income || 0).toLocaleString('id-ID') %>
                </h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>TotalMeja</h6>
                <h3>
                    <%= stats.tables || 0 %>
                </h3>
            </div>
        </div>
    </div>

    <!-- ========================= -->
    <!-- FITUR BARU: CHART -->
    <!-- ========================= -->
    <div class="row g-4 mb-5">
        <div class="col-md-8">
            <div class="card p-3" data-sales-labels="<%= JSON.stringify(salesLabels || []) %>"
                data-sales-data="<%= JSON.stringify(salesData || []) %>">
                <h5>Trend Reservasi</h5>
                <canvas id="salesChart"></canvas>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3" data-console-labels="<%= JSON.stringify(consoleLabels || []) %>"
                data-console-data="<%= JSON.stringify(consoleData || []) %>">
                <h5>Konsol Terlaris</h5>
                <canvas id="consoleChart"></canvas>
            </div>
        </div>
    </div>

    <!-- GALLERY (ANIMASI BERJALAN) -->
    <div class="mb-5 overflow-hidden position-relative">
        <h5 class="fw-bold mb-3"><i class="fa-solid fa-images me-2 text-primary"></i>Galeri PlayStation</h5>
        <div class="marquee-container">
            <div class="marquee-content">
                <!-- 6 Gambar Asli -->
                <img src="https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1552820728-8b83bb6b773f?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1627856013091-fed6e4e30025?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1593305841991-05c297ba4575?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1493711662062-fa541adb3fc8?q=80&w=600">

                <!-- Duplikat 6 Gambar untuk efek looping (infinite) -->
                <img src="https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1552820728-8b83bb6b773f?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1627856013091-fed6e4e30025?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1593305841991-05c297ba4575?q=80&w=600">
                <img src="https://images.unsplash.com/photo-1493711662062-fa541adb3fc8?q=80&w=600">
            </div>
        </div>
    </div>

    <!-- STYLE -->
    <style>
        /* ========================= */
        /* 🎮 BASE UI CYBER DARK */
        /* ========================= */
        body {
            background: #0b0f1a;
            color: #e6e9f2;
        }

        /* HERO */
        .bg-dark {
            background: linear-gradient(135deg,
                    rgba(11, 15, 26, 0.92),
                    rgba(11, 15, 26, 0.75)) !important;
            border: 1px solid rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(6px);
        }

        .bg-dark img {
            opacity: 0.22 !important;
            filter: brightness(0.85);
        }

        /* AKSEN */
        .text-warning {
            color: #7dd3fc !important;
            text-shadow: 0 0 6px rgba(125, 211, 252, 0.3);
        }

        /* ========================= */
        /* CARD */
        /* ========================= */
        .card {
            background: rgba(20, 26, 45, 0.88) !important;
            border: 1px solid rgba(255, 255, 255, 0.05) !important;
            backdrop-filter: blur(8px);
            border-radius: 12px;
            transition: 0.25s;
        }

        .card h5,
        .card h6,
        h3,
        h4 {
            color: #ffffff !important;
        }

        .card-text,
        .text-muted {
            color: #9aa4c0 !important;
        }

        /* BORDER ACCENT */
        .border-primary {
            border-color: #38bdf8 !important;
        }

        .border-danger {
            border-color: #fb7185 !important;
        }

        .border-warning {
            border-color: #c084fc !important;
        }

        /* ICON */
        .bg-primary {
            background: rgba(56, 189, 248, 0.12) !important;
            color: #38bdf8 !important;
        }

        .bg-danger {
            background: rgba(251, 113, 133, 0.12) !important;
            color: #fb7185 !important;
        }

        /* LINK */
        a {
            color: #7dd3fc;
        }

        a:hover {
            text-shadow: 0 0 6px rgba(125, 211, 252, 0.4);
        }

        /* BADGE */
        .badge {
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* HOVER */
        .hover-lift {
            transition: 0.25s;
        }

        .hover-lift:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
        }

        /* STATS & CHART */
        .card.shadow-sm.p-3,
        .card.p-3 {
            background: rgba(20, 26, 45, 0.92) !important;
        }

        /* ========================= */
        /* 🎮 GALLERY (TIDAK DIUBAH STRUKTUR) */
        /* ========================= */

        /* container tetap */
        .marquee-container {
            width: 100%;
            overflow: hidden;
            white-space: nowrap;
            padding-bottom: 10px;
        }

        /* konten tetap animasi asli */
        .marquee-content {
            display: inline-flex;
            gap: 1rem;
            animation: scroll 25s linear infinite;
        }

        .marquee-content:hover {
            animation-play-state: paused;
        }

        /* hanya visual diperbaiki */
        .marquee-content img {
            height: 220px;
            width: 320px;
            object-fit: cover;
            border-radius: 0.75rem;

            box-shadow: 0 0 10px rgba(0, 0, 0, 0.6);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .marquee-content img:hover {
            transform: scale(1.06);
            box-shadow: 0 0 18px rgba(125, 211, 252, 0.25);
        }

        /* animasi tetap */
        @keyframes scroll {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(calc(-50% - 0.5rem));
            }
        }

        .text-accent {
        color: #7dd3fc;
        text-shadow: 0 0 6px rgba(125,211,252,0.4);
        }

        /* JUDUL GALLERY */
        h5 i {
            color: #7dd3fc !important;
        }
    </style>

    <!-- ========================= -->
    <!-- SCRIPT CHART (DARI KODE BARU) -->
    <!-- ========================= -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const salesCard = document.querySelector('[data-sales-labels]');
            const consoleCard = document.querySelector('[data-console-labels]');

            const salesLabels = JSON.parse(salesCard.dataset.salesLabels || '[]');
            const salesData = JSON.parse(salesCard.dataset.salesData || '[]');

            const consoleLabels = JSON.parse(consoleCard.dataset.consoleLabels || '[]');
            const consoleData = JSON.parse(consoleCard.dataset.consoleData || '[]');

            new Chart(document.getElementById('salesChart'), {
                type: 'line',
                data: {
                    labels: salesLabels,
                    datasets: [{
                        data: salesData,
                        borderWidth: 2
                    }]
                }
            });

            new Chart(document.getElementById('consoleChart'), {
                type: 'doughnut',
                data: {
                    labels: consoleLabels,
                    datasets: [{
                        data: consoleData
                    }]
                }
            });
        });
    </script>

    
<style>
/* ========================= */
/* DARK MODE - DASHBOARD */
/* ========================= */
body { background: #0b0f1a !important; color: #e6e9f2 !important; }

.card {
    background: rgba(20, 26, 45, 0.95) !important;
    border: 1px solid rgba(255,255,255,0.06) !important;
    color: #e6e9f2 !important;
}
.card h5, .card h6, .card h3, .card h4 { color: #e6e9f2 !important; }
.card-title { color: #9aa4c0 !important; }
.card-text, .text-muted { color: #9aa4c0 !important; }
.text-dark { color: #e6e9f2 !important; }
.text-secondary { color: #9aa4c0 !important; }

/* BORDER ACCENT */
.border-primary { border-color: #38bdf8 !important; }
.border-danger { border-color: #fb7185 !important; }
.border-warning { border-color: #c084fc !important; }

/* ICON CIRCLES */
.bg-primary { background: rgba(56,189,248,0.15) !important; color: #38bdf8 !important; }
.bg-danger { background: rgba(251,113,133,0.15) !important; color: #fb7185 !important; }
.text-primary { color: #38bdf8 !important; }
.text-warning { color: #7dd3fc !important; text-shadow: 0 0 6px rgba(125,211,252,0.3); }

/* HERO */
.bg-dark {
    background: linear-gradient(135deg, rgba(11,15,26,0.92), rgba(11,15,26,0.75)) !important;
    border: 1px solid rgba(255,255,255,0.05);
}

/* HOVER LIFT */
.hover-lift:hover {
    box-shadow: 0 8px 20px rgba(0,0,0,0.4) !important;
}

