.marquee-content img {
    box-shadow: 0 0 10px rgba(0,0,0,0.6);
}
.marquee-content img:hover {
    box-shadow: 0 0 18px rgba(125,211,252,0.25);
}

/* LIST TEXT */
li { color: #e6e9f2 !important; }

/* LINK */
a.text-success { color: #4ade80 !important; }
</style>

<%- include('layout/footer') %>