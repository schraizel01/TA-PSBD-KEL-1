<%- include('../layout/header') %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-tv text-primary me-2"></i>Daftar Meja PlayStation</h3>
        <p class="text-muted mb-0">Lihat ketersediaan meja PS secara real-time</p>
    </div>
    <a href="/customer/reservations" class="btn btn-primary">
        <i class="fa-solid fa-calendar-plus me-1"></i> Buat Reservasi
    </a>
</div>

<!-- Legend -->
<div class="d-flex gap-3 mb-4 flex-wrap">
    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2">
        <i class="fa-solid fa-circle-check me-1"></i> Tersedia
    </span>
    <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2">
        <i class="fa-solid fa-circle-xmark me-1"></i> Tidak Tersedia
    </span>
</div>

<!-- Filter Status -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <label for="statusFilter" class="form-label fw-semibold">
            <i class="fa-solid fa-filter me-1 text-primary"></i> Filter Status Meja
        </label>
        <select id="statusFilter" class="form-select">
            <option value="all">Semua Status</option>
            <option value="Available">Tersedia</option>
            <option value="Unavailable">Tidak Tersedia</option>
        </select>
    </div>
</div>

<!-- Grid Meja -->
<div class="row g-4" id="tablesContainer">
    <% if (tables.length === 0) { %>
        <div class="col-12 text-center py-5">
            <i class="fa-solid fa-inbox text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-3">Belum ada meja yang terdaftar.</p>
        </div>
    <% } else { %>
        <% tables.forEach(table => { %>
        <div class="col-md-4 col-lg-3 table-card" data-status="<%= table.status %>">
            <div class="card shadow-sm border-0 h-100 text-center
                <% if (table.status === 'Available') { %> border-start border-success border-4
                <% } else { %> border-start border-danger border-4 <% } %>">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <% if (table.status === 'Available') { %>
                            <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                <i class="fa-solid fa-gamepad fs-3"></i>
                            </div>
                        <% } else { %>
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                <i class="fa-solid fa-circle-xmark fs-3"></i>
                            </div>
                        <% } %>
                    </div>

                    <h5 class="fw-bold"><%= table.table_number %></h5>

                    <% if (table.status === 'Available') { %>
                        <span class="badge bg-success px-3 py-1">Tersedia</span>
                    <% } else { %>
                        <span class="badge bg-danger px-3 py-1">Tidak Tersedia</span>
                    <% } %>
                </div>
            </div>
        </div>
        <% }) %>
    <% } %>
</div>

<!-- Empty Result Message -->
<div id="emptyFilterMessage" class="text-center py-5 d-none">
    <i class="fa-solid fa-magnifying-glass text-muted" style="font-size: 3rem;"></i>
    <p class="text-muted mt-3">Tidak ada meja dengan status yang dipilih.</p>
</div>

<script>
    const statusFilter = document.getElementById('statusFilter');
    const tableCards = document.querySelectorAll('.table-card');
    const emptyFilterMessage = document.getElementById('emptyFilterMessage');

    statusFilter.addEventListener('change', function () {
        const selectedStatus = this.value;
        let visibleCount = 0;

        tableCards.forEach(card => {
            const cardStatus = card.getAttribute('data-status');

            if (selectedStatus === 'all' || cardStatus === selectedStatus) {
                card.classList.remove('d-none');
                visibleCount++;
            } else {
                card.classList.add('d-none');
            }
        });

        if (visibleCount === 0 && tableCards.length > 0) {
            emptyFilterMessage.classList.remove('d-none');
        } else {
            emptyFilterMessage.classList.add('d-none');
        }
    });
</script>

<%- include('../layout/footer') %>