<%- include('../layout/header') %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fa-solid fa-tv text-primary me-2"></i>Manajemen Meja PlayStation</h3>
        <p class="text-muted mb-0">Kelola semua unit meja PS yang tersedia</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/admin/tables/trash" class="btn btn-outline-secondary">
            <i class="fa-solid fa-trash-can me-1"></i> Recycle Bin (<%= trashCount %>)
        </a>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTableModal">
            <i class="fa-solid fa-plus me-1"></i> Tambah Meja
        </button>
    </div>
</div>

<!-- Tabel Data Meja -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <% if (tables.length === 0) { %>
            <div class="text-center py-5">
                <i class="fa-solid fa-inbox text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-3 mb-0">Belum ada meja. Klik <strong>"Tambah Meja"</strong> untuk memulai.</p>
            </div>
        <% } else { %>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="bg-light">
                        <th class="ps-4" style="width: 60px;">No</th>
                        <th><i class="fa-solid fa-hashtag text-muted me-1"></i> Kode Meja</th>
                        <th><i class="fa-solid fa-circle-info text-muted me-1"></i> Status</th>
                        <th class="text-center" style="width: 220px;"><i class="fa-solid fa-gear text-muted me-1"></i> Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% tables.forEach((t, index) => { %>
                    <tr style="background:#0d1b2e !important;">
                        <td class="ps-4 fw-bold" style="background:#0d1b2e !important; color:#7a99bb !important;"><%= index + 1 %></td>
                        <td style="background:#0d1b2e !important;">
                            <div class="d-flex align-items-center">
                                <div style="width:40px;height:40px;border-radius:8px;background:rgba(0,240,255,0.08);border:1px solid rgba(0,240,255,0.2);color:#00f0ff;display:flex;align-items:center;justify-content:center;margin-right:12px;box-shadow:0 0 10px rgba(0,240,255,0.12);">
                                    <i class="fa-solid fa-gamepad"></i>
                                </div>
                                <span class="fw-semibold" style="color:#e2f0ff;"><%= t.table_number %></span>
                            </div>
                        </td>
                        <td style="background:#0d1b2e !important;">
                            <% if (t.status === 'Available') { %>
                                <span class="badge px-3 py-2" style="background:rgba(0,255,136,0.08);color:#00ff88;border:1px solid rgba(0,255,136,0.25);border-radius:4px;font-weight:600;">
                                    <i class="fa-solid fa-circle-check me-1"></i> Tersedia
                                </span>
                            <% } else if (t.status === 'In Use') { %>
                                <span class="badge px-3 py-2" style="background:rgba(255,69,96,0.08);color:#ff4560;border:1px solid rgba(255,69,96,0.25);border-radius:4px;font-weight:600;">
                                    <i class="fa-solid fa-circle-play me-1"></i> Sedang Dipakai
                                </span>
                            <% } else { %>
                                <span class="badge px-3 py-2" style="background:rgba(255,208,0,0.08);color:#ffd000;border:1px solid rgba(255,208,0,0.25);border-radius:4px;font-weight:600;">
                                    <i class="fa-solid fa-wrench me-1"></i> Maintenance
                                </span>
                            <% } %>
                        </td>
                        <td class="text-center" style="background:#0d1b2e !important;">
                            <button class="btn btn-sm btn-outline-primary me-1" data-bs-toggle="modal" data-bs-target="#editTableModal<%= t.id %>">
                                <i class="fa-solid fa-pen-to-square me-1"></i> Edit
                            </button>
                            <form action="/admin/tables/delete/<%= t.id %>" method="POST" class="d-inline"
                                  onsubmit="confirmAction(event, 'Hapus Meja?', 'Meja akan dipindahkan ke Recycle Bin.', this, 'Ya, Hapus!', '#dc3545')">
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-trash me-1"></i> Hapus
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- Modal Edit Meja -->
                    <div class="modal fade" id="editTableModal<%= t.id %>" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content border-0 shadow">
                                <div class="modal-header bg-primary bg-opacity-10">
                                    <h5 class="modal-title text-primary fw-bold">
                                        <i class="fa-solid fa-pen-to-square me-2"></i>Edit Meja <%= t.table_number %>
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form action="/admin/tables/update/<%= t.id %>" method="POST">
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Nomor / Kode Meja</label>
                                            <input type="text" name="table_number" class="form-control" value="<%= t.table_number %>" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Status</label>
                                            <select name="status" class="form-select">
                                                <option value="Available" <%= t.status === 'Available' ? 'selected' : '' %>>✅ Available</option>
                                                <option value="In Use" <%= t.status === 'In Use' ? 'selected' : '' %>>🎮 In Use</option>
                                                <option value="Maintenance" <%= t.status === 'Maintenance' ? 'selected' : '' %>>🔧 Maintenance</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fa-solid fa-floppy-disk me-1"></i> Simpan Perubahan
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
    <% if (tables.length > 0) { %>
    <div class="card-footer text-muted small py-3 px-4">
        <i class="fa-solid fa-circle-info me-1"></i> Total: <strong><%= tables.length %></strong> meja terdaftar
    </div>
    <% } %>
</div>

<!-- Modal Tambah Meja -->
<div class="modal fade" id="addTableModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-plus me-2"></i>Tambah Meja Baru</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/tables" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nomor / Kode Meja</label>
                        <input type="text" name="table_number" class="form-control form-control-lg" placeholder="Contoh: PS5-01" required>
                        <div class="form-text">Gunakan format: <code>PS5-01</code>, <code>PS4-02</code>, dll.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Simpan
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
/* CARD wrapper */
.card {
    background: #0a1628 !important;
    border: 1px solid rgba(0,240,255,0.15) !important;
    border-radius: 12px !important;
    box-shadow: 0 0 30px rgba(0,180,255,0.08), inset 0 1px 0 rgba(0,240,255,0.07) !important;
    overflow: hidden;
}

/* Glowing top border */
.card::before {
    content: '';
    position: absolute;
    top: 0; left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #00f0ff, transparent);
    opacity: 0.4;
}

.card-footer {
    background: rgba(0,0,0,0.3) !important;
    border-top: 1px solid rgba(255,255,255,0.05) !important;
    color: #7a99bb !important;
}

/* THEAD */
.table thead tr,
.table thead tr.bg-light,
.table > thead > tr > th {
    background: rgba(0,240,255,0.05) !important;
    color: #00f0ff !important;
    border-bottom: 1px solid rgba(0,240,255,0.15) !important;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
}

/* Hover row */
.table-hover > tbody > tr:hover > td {
    background: #112240 !important;
    box-shadow: inset 3px 0 0 #00f0ff !important;
}

/* BORDER antar row */
.table > tbody > tr > td {
    border-bottom: 1px solid rgba(255,255,255,0.04) !important;
}
</style>

<%- include('../layout/footer') %>
