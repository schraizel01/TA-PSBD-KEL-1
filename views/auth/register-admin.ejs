<!DOCTYPE html>
<html lang="id">
<head>
    <title>Register Admin - Rental PS</title>

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <!-- Bootstrap & Icon -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top, #14001f, #0a0f1c, #000000);
            min-height: 100vh;
            color: #e0e0e0;
        }

        .cyber-card {
            background: rgba(10, 15, 28, 0.85);
            border: 1px solid rgba(255, 0, 150, 0.3);
            border-radius: 15px;
            backdrop-filter: blur(12px);
            box-shadow: 0 0 25px rgba(255, 0, 150, 0.15);
        }

        .cyber-title {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 2px;
            color: #ff0099;
            text-shadow: 0 0 10px #ff0099;
        }

        .form-control {
            background-color: #0a0f1c;
            border: 1px solid #ff009944;
            color: #fff;
        }

        .form-control:focus {
            background-color: #0a0f1c;
            border-color: #ff0099;
            box-shadow: 0 0 10px #ff0099;
            color: #fff;
        }

        .btn-cyber-admin {
            background: linear-gradient(90deg, #ff0099, #8a2be2);
            border: none;
            color: white;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-cyber-admin:hover {
            box-shadow: 0 0 15px #ff0099, 0 0 25px #8a2be2;
            transform: scale(1.02);
        }

        a {
            color: #ff0099;
        }

        a:hover {
            text-shadow: 0 0 6px #ff0099;
        }

        .icon-glow {
            color: #ff0099;
            text-shadow: 0 0 12px #ff0099;
        }

        hr {
            border-color: #ff009933;
        }
    </style>
</head>

<body class="d-flex align-items-center">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4">

            <div class="text-center mb-4">
                <i class="fa-solid fa-shield-halved icon-glow" style="font-size: 2.5rem;"></i>
                <h4 class="fw-bold mt-2 mb-0 cyber-title">ADMIN ACCESS</h4>
                <p class="text-white-50 small">Authorized personnel only</p>
            </div>

            <div class="card cyber-card">
                <div class="card-body p-4">

                    <form action="/auth/register-admin" method="POST">

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Username</label>
                            <input type="text" name="username" class="form-control" placeholder="admin_id" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Password</label>
                            <input type="password" name="password" class="form-control" placeholder="min. 6 karakter" minlength="6" required>
                        </div>

                        <button class="btn btn-cyber-admin w-100 py-2">
                            REGISTER ADMIN
                        </button>

                    </form>

                    <hr>

                    <div class="text-center">
                        <a href="/auth/login" class="small">
                            ← Kembali ke Login
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

</body>
</html>