<!DOCTYPE html>
<html lang="id">
<head>
    <title>Daftar - Rental PS</title>

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <!-- Bootstrap & Icon -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top, #001f2f, #0a0f1c, #000000);
            min-height: 100vh;
            color: #e0e0e0;
        }

        .cyber-card {
            background: rgba(10, 15, 28, 0.85);
            border: 1px solid rgba(0, 255, 200, 0.25);
            border-radius: 15px;
            backdrop-filter: blur(12px);
            box-shadow: 0 0 20px rgba(0, 255, 200, 0.1);
        }

        .cyber-title {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 2px;
            color: #00ffd5;
            text-shadow: 0 0 10px #00ffd5;
        }

        .form-control {
            background-color: #0a0f1c;
            border: 1px solid #00ffd544;
            color: #fff;
        }

        .form-control:focus {
            background-color: #0a0f1c;
            border-color: #00ffd5;
            box-shadow: 0 0 10px #00ffd5;
            color: #fff;
        }

        .btn-cyber-user {
            background: linear-gradient(90deg, #00ffd5, #00aaff);
            border: none;
            color: black;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-cyber-user:hover {
            box-shadow: 0 0 15px #00ffd5, 0 0 25px #00aaff;
            transform: scale(1.02);
        }

        a {
            color: #00ffd5;
        }

        a:hover {
            text-shadow: 0 0 6px #00ffd5;
        }

        .icon-glow {
            color: #00ffd5;
            text-shadow: 0 0 12px #00ffd5;
        }

        hr {
            border-color: #00ffd533;
        }
    </style>
</head>

<body class="d-flex align-items-center">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4">

            <div class="text-center mb-4">
                <i class="fa-solid fa-gamepad icon-glow" style="font-size: 2.5rem;"></i>
                <h4 class="fw-bold mt-2 mb-0 cyber-title">CREATE ACCOUNT</h4>
                <p class="text-white-50 small">Join the system</p>
            </div>

            <div class="card cyber-card">
                <div class="card-body p-4">

                    <form action="/auth/register" method="POST">

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nama Lengkap</label>
                            <input type="text" name="name" class="form-control" placeholder="Nama anda" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nomor HP / WhatsApp</label>
                            <input type="tel" name="phone" class="form-control" placeholder="08xxxxxxxxxx" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="email@gmail.com" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Password</label>
                            <input type="password" name="password" class="form-control" placeholder="min. 6 karakter" minlength="6" required>
                        </div>

                        <button class="btn btn-cyber-user w-100 py-2">
                            DAFTAR
                        </button>

                    </form>

                    <hr>

                    <div class="text-center">
                        <a href="/auth/login" class="small">
                            Sudah punya akun? <strong>Login</strong>
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

</body>
</html>